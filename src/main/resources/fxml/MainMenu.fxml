<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.sportsmanager.ui.controller.MainMenuController"
           prefWidth="900" prefHeight="700"
           style="-fx-background-color: #0d0d1a;">

    <!-- Decorative background layer -->
    <Pane mouseTransparent="true" prefWidth="900" prefHeight="700">
        <!-- Left panel fill -->
        <Rectangle x="0" y="0" width="250" height="700"
                   style="-fx-fill: linear-gradient(from 0% 0% to 100% 0%, #16213e 55%, #0d0d1a 100%);"/>

        <!-- Outer frame: top edge -->
        <Rectangle x="0" y="0" width="900" height="2" style="-fx-fill: #e94560;"/>
        <!-- Outer frame: left edge -->
        <Rectangle x="0" y="0" width="2" height="700" style="-fx-fill: #e94560;"/>
        <!-- Outer frame: bottom edge -->
        <Rectangle x="0" y="698" width="900" height="2" style="-fx-fill: #e94560;" opacity="0.45"/>
        <!-- Outer frame: right edge -->
        <Rectangle x="898" y="0" width="2" height="700" style="-fx-fill: #e94560;" opacity="0.25"/>

        <!-- Corner bracket: top-left -->
        <Rectangle x="2" y="2" width="52" height="2" style="-fx-fill: #e94560;"/>
        <Rectangle x="2" y="2" width="2" height="52" style="-fx-fill: #e94560;"/>
        <!-- Corner bracket: top-right -->
        <Rectangle x="846" y="2" width="52" height="2" style="-fx-fill: #e94560;" opacity="0.4"/>
        <Rectangle x="896" y="2" width="2" height="52" style="-fx-fill: #e94560;" opacity="0.4"/>
        <!-- Corner bracket: bottom-left -->
        <Rectangle x="2" y="696" width="52" height="2" style="-fx-fill: #e94560;" opacity="0.4"/>
        <Rectangle x="2" y="646" width="2" height="52" style="-fx-fill: #e94560;" opacity="0.4"/>
        <!-- Corner bracket: bottom-right -->
        <Rectangle x="846" y="696" width="52" height="2" style="-fx-fill: #e94560;" opacity="0.2"/>
        <Rectangle x="896" y="646" width="2" height="52" style="-fx-fill: #e94560;" opacity="0.2"/>

        <!-- Panel divider -->
        <Rectangle x="249" y="0" width="1" height="700" style="-fx-fill: #e94560;" opacity="0.22"/>

        <!-- Horizontal grid lines in left panel -->
        <Rectangle x="16" y="178" width="218" height="1" style="-fx-fill: #e94560;" opacity="0.07"/>
        <Rectangle x="16" y="356" width="218" height="1" style="-fx-fill: #e94560;" opacity="0.07"/>
        <Rectangle x="16" y="534" width="218" height="1" style="-fx-fill: #e94560;" opacity="0.07"/>

        <!-- Status dot and bar at top of left panel -->
        <Rectangle x="20" y="22" width="7" height="7" arcWidth="7" arcHeight="7" style="-fx-fill: #22c55e;"/>
        <Rectangle x="32" y="24" width="28" height="3" style="-fx-fill: #22c55e;" opacity="0.35"/>
        <Rectangle x="64" y="24" width="14" height="3" style="-fx-fill: #22c55e;" opacity="0.15"/>
    </Pane>

    <!-- Main layout -->
    <HBox prefWidth="900" prefHeight="700">

        <!-- Left side: decorative data panel -->
        <VBox prefWidth="250" prefHeight="700" alignment="TOP_LEFT"
              style="-fx-padding: 16 28 28 20;">
            <Region prefHeight="12"/>
            <Label text="● LIVE"
                   style="-fx-text-fill: #22c55e; -fx-font-family: 'Courier New'; -fx-font-size: 10; -fx-font-weight: bold;"/>
            <Region prefHeight="56"/>

            <Label text="SEZON"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 9; -fx-font-weight: bold; -fx-opacity: 0.3;"/>
            <Label text="2024"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 30; -fx-font-weight: bold;"/>
            <Region prefHeight="30"/>

            <Label text="LİGLER"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 9; -fx-font-weight: bold; -fx-opacity: 0.3;"/>
            <Label text="02"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 30; -fx-font-weight: bold;"/>
            <Region prefHeight="30"/>

            <Label text="SPORLAR"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 9; -fx-font-weight: bold; -fx-opacity: 0.3;"/>
            <Label text="02"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 30; -fx-font-weight: bold;"/>
            <Region prefHeight="30"/>

            <Label text="TAKIMLAR"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 9; -fx-font-weight: bold; -fx-opacity: 0.3;"/>
            <Label text="40+"
                   style="-fx-text-fill: #e94560; -fx-font-family: 'Courier New'; -fx-font-size: 30; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, #e94560, 14, 0.4, 0, 0);"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="v1.0.0-alpha"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 9; -fx-opacity: 0.18;"/>
        </VBox>

        <!-- Right side: main content -->
        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
              style="-fx-padding: 56 68 56 60;">

            <!-- Title -->
            <Label text="SPORTS"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Impact'; -fx-font-size: 78; -fx-opacity: 0.92;"/>
            <Label text="MANAGER"
                   style="-fx-text-fill: #e94560; -fx-font-family: 'Impact'; -fx-font-size: 78; -fx-effect: dropshadow(gaussian, #e94560, 38, 0.42, 0, 0);"/>
            <Label text="THE  GAME"
                   style="-fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 12; -fx-font-weight: bold; -fx-opacity: 0.22;"/>

            <!-- Divider -->
            <Region prefHeight="26"/>
            <Rectangle width="460" height="1" style="-fx-fill: #e94560;" opacity="0.45"/>
            <Region prefHeight="26"/>

            <!-- Sport selection -->
            <Label text="SPOR"
                   style="-fx-text-fill: #e94560; -fx-font-family: 'Courier New'; -fx-font-size: 10; -fx-font-weight: bold;"/>
            <Region prefHeight="8"/>
            <ComboBox fx:id="sportComboBox" prefWidth="460" prefHeight="44"
                      style="-fx-background-color: #16213e; -fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 14; -fx-border-color: #0f3460; -fx-border-width: 1; -fx-background-radius: 0; -fx-border-radius: 0;"/>

            <Region prefHeight="18"/>

            <!-- Team name -->
            <Label text="TAKIM ADI (OPSİYONEL)"
                   style="-fx-text-fill: #e94560; -fx-font-family: 'Courier New'; -fx-font-size: 10; -fx-font-weight: bold;"/>
            <Region prefHeight="8"/>
            <TextField fx:id="teamNameField" prefWidth="460" prefHeight="44"
                       promptText="Takım adı girin..."
                       style="-fx-background-color: #16213e; -fx-text-fill: #eaeaea; -fx-prompt-text-fill: rgba(234,234,234,0.22); -fx-font-family: 'Courier New'; -fx-font-size: 14; -fx-border-color: #0f3460; -fx-border-width: 1; -fx-background-radius: 0; -fx-border-radius: 0; -fx-padding: 0 12;"/>

            <!-- Action buttons -->
            <Region prefHeight="34"/>
            <VBox spacing="10">
                <Button text="▶   YENİ OYUN" onAction="#onNewGame"
                        prefWidth="460" prefHeight="52"
                        style="-fx-background-color: #e94560; -fx-text-fill: #ffffff; -fx-font-family: 'Courier New'; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #e94560, 26, 0.42, 0, 6);"/>
                <Button text="◉   OYUN YÜKLE" onAction="#onLoadGame"
                        prefWidth="460" prefHeight="46"
                        style="-fx-background-color: #0f3460; -fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 0; -fx-cursor: hand; -fx-border-color: rgba(22,33,62,0.5); -fx-border-width: 1;"/>
                <Button text="✕   ÇIKIŞ" onAction="#onQuit"
                        prefWidth="460" prefHeight="38"
                        style="-fx-background-color: transparent; -fx-text-fill: #eaeaea; -fx-font-family: 'Courier New'; -fx-font-size: 13; -fx-opacity: 0.28; -fx-background-radius: 0; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </HBox>

</StackPane>
