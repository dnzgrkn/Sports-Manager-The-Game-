<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sportsmanager.ui.controller.LeagueController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #0d0d1a;">

    <stylesheets>
        <URL value="@../css/league.css"/>
    </stylesheets>

    <!-- ═══ LEFT PANEL ═══════════════════════════════════════ -->
    <left>
        <VBox prefWidth="200" prefHeight="700"
              style="-fx-background-color: #16213e;
                     -fx-padding: 28 20 28 20;
                     -fx-border-color: transparent #e94560 transparent transparent;
                     -fx-border-width: 0 1 0 0;">

            <!-- Week display -->
            <Label text="HAFTA"
                   style="-fx-text-fill: #eaeaea;
                          -fx-font-family: 'Courier New';
                          -fx-font-size: 10;
                          -fx-font-weight: bold;
                          -fx-opacity: 0.32;"/>
            <Label fx:id="weekLabel" text="0 / 0"
                   style="-fx-text-fill: #eaeaea;
                          -fx-font-family: 'Courier New';
                          -fx-font-size: 32;
                          -fx-font-weight: bold;"/>

            <Region prefHeight="26"/>

            <!-- Action buttons -->
            <Button text="HAFTAYI İLERLET" onAction="#onAdvanceWeek"
                    prefWidth="160" prefHeight="46"
                    style="-fx-background-color: #e94560;
                           -fx-text-fill: #ffffff;
                           -fx-font-family: 'Courier New';
                           -fx-font-size: 12;
                           -fx-font-weight: bold;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, #e94560, 16, 0.35, 0, 4);"/>
            <Region prefHeight="10"/>
            <Button text="ANTRENMAN" onAction="#onTraining"
                    prefWidth="160" prefHeight="38"
                    style="-fx-background-color: #0f3460;
                           -fx-text-fill: #eaeaea;
                           -fx-font-family: 'Courier New';
                           -fx-font-size: 12;
                           -fx-font-weight: bold;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;"/>
            <Region prefHeight="10"/>
            <Button text="OYUNU KAYDET" onAction="#onSaveGame"
                    prefWidth="160" prefHeight="38"
                    style="-fx-background-color: #0f3460;
                           -fx-text-fill: #eaeaea;
                           -fx-font-family: 'Courier New';
                           -fx-font-size: 12;
                           -fx-font-weight: bold;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;"/>
            <Region prefHeight="10"/>
            <Button text="OYUNU YÜKLE" onAction="#onLoadGame"
                    prefWidth="160" prefHeight="38"
                    style="-fx-background-color: #0f3460;
                           -fx-text-fill: #eaeaea;
                           -fx-font-family: 'Courier New';
                           -fx-font-size: 12;
                           -fx-font-weight: bold;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;"/>

            <Region prefHeight="32"/>

            <!-- Divider -->
            <Region prefHeight="1" prefWidth="160"
                    style="-fx-background-color: #e94560; -fx-opacity: 0.2;"/>

            <Region prefHeight="28"/>

            <!-- Next match info -->
            <Label text="SIRADAKİ MAÇIN:"
                   style="-fx-text-fill: #eaeaea;
                          -fx-font-family: 'Courier New';
                          -fx-font-size: 9;
                          -fx-font-weight: bold;
                          -fx-opacity: 0.38;"/>
            <Region prefHeight="8"/>
            <Label fx:id="nextOpponentLabel" text="-"
                   style="-fx-text-fill: #e94560;
                          -fx-font-family: 'Courier New';
                          -fx-font-size: 15;
                          -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, #e94560, 10, 0.3, 0, 0);"/>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ═══ CENTER: Tab Pane ══════════════════════════════════ -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- Standings tab -->
            <Tab text="PUAN TABLOSU">
                <content>
                    <TableView fx:id="standingsTable">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="rankColumn"         text="#"     prefWidth="38"/>
                            <TableColumn fx:id="teamColumn"         text="TAKIM" prefWidth="170"/>
                            <TableColumn fx:id="playedColumn"       text="O"     prefWidth="38"/>
                            <TableColumn fx:id="winsColumn"         text="G"     prefWidth="38"/>
                            <TableColumn fx:id="drawsColumn"        text="B"     prefWidth="38"/>
                            <TableColumn fx:id="lossesColumn"       text="M"     prefWidth="38"/>
                            <TableColumn fx:id="goalsForColumn"     text="GA"    prefWidth="44"/>
                            <TableColumn fx:id="goalsAgainstColumn" text="GY"    prefWidth="44"/>
                            <TableColumn fx:id="goalDiffColumn"     text="AV"    prefWidth="48"/>
                            <TableColumn fx:id="pointsColumn"       text="PTS"   prefWidth="52"/>
                        </columns>
                    </TableView>
                </content>
            </Tab>

            <!-- Fixture tab -->
            <Tab text="FİKSTÜR">
                <content>
                    <ListView fx:id="fixtureList"/>
                </content>
            </Tab>

        </TabPane>
    </center>

    <!-- ═══ RIGHT PANEL: Squad ════════════════════════════════ -->
    <right>
        <VBox prefWidth="180" prefHeight="700"
              style="-fx-background-color: #16213e;
                     -fx-padding: 28 16 28 16;
                     -fx-border-color: transparent transparent transparent #e94560;
                     -fx-border-width: 0 0 0 1;">

            <Label text="KADROM"
                   style="-fx-text-fill: #e94560;
                          -fx-font-family: 'Courier New';
                          -fx-font-size: 13;
                          -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, #e94560, 8, 0.25, 0, 0);"/>
            <Region prefHeight="16"/>

            <ListView fx:id="squadList" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
        </VBox>
    </right>

</BorderPane>
